---
import Layout from '@/layouts/Layout.astro';
import Container from '@/components/Container.astro';
import { Button } from '@/components/ui/button';
import Link from '@/components/Link.astro';
---

<Layout
  title="Om OTG Solutions | Utviklere i Fredrikstad"
  description="OTG Solutions bygger programvare og apper for bedrifter i Fredrikstad og Oslo."
>
  <Container>
    <div class="py-24 max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold mb-8 text-center">Om oss</h1>

      <div class="space-y-6 text-lg text-gray-600 mb-16">
        <p>
          Vi er utviklere fra Fredrikstad som bygger programvare og apper for bedrifter. Enkelt og greit.
        </p>

        <p>
          Hos oss snakker du direkte med folkene som bygger løsningen. Ingen mellomledd, ingen konsulenter som må sette seg inn i alt fra scratch.
        </p>

        <p>
          Vi leverer ikke før det holder mål.
        </p>
      </div>

      <div class="text-center">
        <h2 class="text-2xl font-semibold mb-6">Vil du snakke med oss?</h2>
        <Link href="/kontakt/" ariaLabel="Lenke til kontakt oss">
          <Button variant="default" size="lg">Ta kontakt</Button>
        </Link>
      </div>
    </div>
  </Container>
</Layout>
