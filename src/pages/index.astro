---
import Layout from '@/layouts/Layout.astro';
import Container from '@/components/Container.astro';
import { Button } from '@/components/ui/button';
import { Card, CardHeader, CardTitle, CardDescription, CardContent } from '@/components/ui/card';
import HeroSection from '@/components/hero-section.astro';
import Link from '@/components/Link.astro';
---

<Layout
  title="OTG Solutions AS | IT-utvikling og konsulenttjenester i Fredrikstad og Oslo"
  description="OTG Solutions utvikler programvare og apper for bedrifter i Fredrikstad og Oslo."
>
  <HeroSection
    title="Vi bygger det bedriften din trenger"
    description="Programvare og apper for bedrifter i Fredrikstad og Oslo."
  >
    <div class="flex gap-4 justify-center">
      <Link href="/kontakt/" ariaLabel="Lenke til kontakt oss">
        <Button variant="default" size="lg">Ta kontakt</Button>
      </Link>
      <Link href="/om-oss/" ariaLabel="Lenke til om oss">
        <Button variant="outline" size="lg">Om oss</Button>
      </Link>
    </div>
  </HeroSection>

  <!-- Features Section -->
  <Container>
    <div class="py-20">
      <h2 class="text-3xl font-bold text-center mb-12">Hva vi gjør</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <Card>
          <CardHeader>
            <CardTitle>Programvare</CardTitle>
            <CardDescription>Tilpasset din bedrift</CardDescription>
          </CardHeader>
          <CardContent>
            <p class="text-gray-600">Webapper, interne verktøy og systemer som løser problemet ditt.</p>
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
            <CardTitle>Apper</CardTitle>
            <CardDescription>Mobil og web</CardDescription>
          </CardHeader>
          <CardContent>
            <p class="text-gray-600">Fra idé til ferdig produkt, for kunder eller ansatte.</p>
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
            <CardTitle>Rådgivning</CardTitle>
            <CardDescription>Teknisk sparring</CardDescription>
          </CardHeader>
          <CardContent>
            <p class="text-gray-600">Usikker på teknologivalg? Vi hjelper deg med å finne riktig løsning.</p>
          </CardContent>
        </Card>
      </div>
    </div>
  </Container>

  <!-- Why Choose Us Section -->
  <div class="bg-gray-50 py-20">
    <Container>
      <h2 class="text-3xl font-bold text-center mb-12">Hvordan vi jobber</h2>
      <div class="grid md:grid-cols-2 gap-12 max-w-4xl mx-auto">
        <div>
          <h3 class="text-xl font-semibold mb-3">Lokalt og tilgjengelig</h3>
          <p class="text-gray-600">Vi sitter i Fredrikstad. Du får en utvikler du kan ringe, ikke et ticketsystem.</p>
        </div>
        <div>
          <h3 class="text-xl font-semibold mb-3">Rett teknologi</h3>
          <p class="text-gray-600">Vi velger det som passer prosjektet, ikke det som er trendy. Det skal fungere om fem år også.</p>
        </div>
        <div>
          <h3 class="text-xl font-semibold mb-3">Ingen overraskelser</h3>
          <p class="text-gray-600">Du vet hva vi gjør, hvorfor, og hva det koster.</p>
        </div>
        <div>
          <h3 class="text-xl font-semibold mb-3">Vi leverer</h3>
          <p class="text-gray-600">Vi tar på oss det vi kan gjøre skikkelig. Heller et godt resultat enn store løfter.</p>
        </div>
      </div>
    </Container>
  </div>

  <!-- CTA Section -->
  <Container>
    <div class="py-20 text-center">
      <h2 class="text-3xl font-bold mb-6">Noe du vil snakke om?</h2>
      <p class="text-xl text-gray-600 mb-8 max-w-2xl mx-auto">
        Send oss en melding, så tar vi en prat.
      </p>
      <Link href="/kontakt/" ariaLabel="Lenke til kontakt oss">
        <Button variant="default" size="lg">Ta kontakt</Button>
      </Link>
    </div>
  </Container>
</Layout>
