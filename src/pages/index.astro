---
import Layout from '@/layouts/Layout.astro';
import Container from '@/components/Container.astro';
import { Button } from '@/components/ui/button';
import { Card, CardHeader, CardTitle, CardDescription, CardContent } from '@/components/ui/card';
import HeroSection from '@/components/hero-section.astro';
import Link from '@/components/Link.astro';
---

<Layout
  title="OTG Solutions AS | IT-utvikling og konsulenttjenester i Fredrikstad og Oslo"
  description="OTG Solutions leverer skreddersydd programvareutvikling, app-utvikling og bestillingssystemer for bedrifter i Fredrikstad og Oslo."
>
  <HeroSection
    title="Vi bygger systemene bedriften din trenger"
    description="OTG Solutions utvikler programvare, apper og bestillingssystemer for bedrifter i Fredrikstad og Oslo-området."
  >
    <div class="flex gap-4 justify-center">
      <Link href="/kontakt" ariaLabel="Lenke til kontakt oss">
        <Button variant="default" size="lg">Ta kontakt</Button>
      </Link>
      <Link href="/om-oss" ariaLabel="Lenke til om oss">
        <Button variant="outline" size="lg">Om oss</Button>
      </Link>
    </div>
  </HeroSection>

  <!-- Features Section -->
  <Container>
    <div class="py-20">
      <h2 class="text-3xl font-bold text-center mb-12">Det vi kan hjelpe med</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <Card>
          <CardHeader>
            <CardTitle>Programvareutvikling</CardTitle>
            <CardDescription>Systemer tilpasset din bedrift</CardDescription>
          </CardHeader>
          <CardContent>
            <p class="text-gray-600">Vi bygger webapplikasjoner, bestillingssystemer og interne verktøy som faktisk løser problemet ditt.</p>
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
            <CardTitle>App-utvikling</CardTitle>
            <CardDescription>Mobil og web</CardDescription>
          </CardHeader>
          <CardContent>
            <p class="text-gray-600">Trenger du en app for kunder eller ansatte? Vi tar det fra skisse til ferdig produkt.</p>
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
            <CardTitle>IT-rådgivning</CardTitle>
            <CardDescription>Teknisk sparring og gjennomføring</CardDescription>
          </CardHeader>
          <CardContent>
            <p class="text-gray-600">Usikker på teknologivalg eller hvordan du bør løse det teknisk? Vi hjelper deg å finne riktig vei.</p>
          </CardContent>
        </Card>
      </div>
    </div>
  </Container>

  <!-- Why Choose Us Section -->
  <div class="bg-gray-50 py-20">
    <Container>
      <h2 class="text-3xl font-bold text-center mb-12">Slik jobber vi</h2>
      <div class="grid md:grid-cols-2 gap-12 max-w-4xl mx-auto">
        <div>
          <h3 class="text-xl font-semibold mb-3">Lokalt og tilgjengelig</h3>
          <p class="text-gray-600">Vi holder til i Fredrikstad og jobber tett med kundene våre. Du får en utvikler du kan ringe, ikke et ticketsystem.</p>
        </div>
        <div>
          <h3 class="text-xl font-semibold mb-3">Rett verktøy for jobben</h3>
          <p class="text-gray-600">Vi velger teknologi basert på hva som passer prosjektet, ikke hva som er trendy. Det skal fungere om fem år også.</p>
        </div>
        <div>
          <h3 class="text-xl font-semibold mb-3">Tydelig kommunikasjon</h3>
          <p class="text-gray-600">Du får vite hva vi gjør, hvorfor vi gjør det, og hva det koster. Ingen overraskelser.</p>
        </div>
        <div>
          <h3 class="text-xl font-semibold mb-3">Vi leverer det vi lover</h3>
          <p class="text-gray-600">Vi tar på oss det vi kan gjøre skikkelig. Heller et godt resultat enn store løfter.</p>
        </div>
      </div>
    </Container>
  </div>

  <!-- CTA Section -->
  <Container>
    <div class="py-20 text-center">
      <h2 class="text-3xl font-bold mb-6">Har du et prosjekt i tankene?</h2>
      <p class="text-xl text-gray-600 mb-8 max-w-2xl mx-auto">
        Send oss en melding, så tar vi en uforpliktende prat om hva du trenger.
      </p>
      <Link href="/kontakt" ariaLabel="Lenke til kontakt oss">
        <Button variant="default" size="lg">Ta kontakt</Button>
      </Link>
    </div>
  </Container>
</Layout>
