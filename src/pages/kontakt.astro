---
import Layout from '@/layouts/Layout.astro';
import Container from '@/components/Container.astro';
---

<Layout
  title="Kontakt OTG Solutions | IT-utvikling Fredrikstad og Oslo"
  description="Ta kontakt med OTG Solutions for programvare og apputvikling i Fredrikstad og Oslo."
>
  <Container>
    <div class="py-24 max-w-3xl mx-auto">
      <div class="text-center space-y-6">
        <h1 class="text-4xl font-bold">Kontakt oss</h1>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
          Send oss en epost, så svarer vi så fort vi kan.
        </p>

        <div class="mt-12 space-y-4">
          <h2 class="text-2xl font-semibold">E-post</h2>
          <a href="mailto:post@otg-solutions.no" class="inline-flex items-center text-lg hover:underline text-primary">
            post@otg-solutions.no
          </a>
        </div>
      </div>
    </div>
  </Container>
</Layout>
